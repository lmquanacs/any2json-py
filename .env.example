OPENAI_API_KEY=your_openai_api_key_here

# Optional: keys for other providers via LiteLLM
# ANTHROPIC_API_KEY=your_anthropic_key
# GEMINI_API_KEY=your_gemini_key

# Optional model overrides (LiteLLM format: provider/model-name)
COORDINATOR_MODEL=openai/gpt-4o
WORKER_MODEL=openai/gpt-4o-mini

# File size limit in MB (default: 50)
MAX_FILE_SIZE_MB=50

# Token threshold to trigger multi-agent flow (default: 100000)
CONTEXT_THRESHOLD_TOKENS=100000
